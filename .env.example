# Browser-safe Vite variables (Vercel)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_URL=https://moro-ai-enterprise.vercel.app

# Server-only deployment metadata. Never prefix these with VITE_.
APP_URL=https://moro-ai-enterprise.vercel.app
SITE_URL=https://moro-ai-enterprise.vercel.app

# Provider-neutral SMTP values for local/self-hosted Supabase or secure automation.
# For managed Supabase, enter these in Authentication > SMTP Settings instead.
SMTP_PROVIDER=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=MoroAI

# Supabase Edge Functions only. Never expose this value to the browser or Vercel client build.
SUPABASE_SERVICE_ROLE_KEY=
